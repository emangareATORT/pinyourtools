rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /links/{linkId} {
      // Read is allowed if the user is authenticated and the document belongs to them
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Create is allowed if the user is authenticated and they assign the document to themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Update is allowed if the user owns the document and does not transfer ownership
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid 
                    && request.resource.data.userId == request.auth.uid;
                    
      // Delete is allowed if the user owns the document
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
